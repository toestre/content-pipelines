      "parameters": {
        "jsCode": "return [{\n  json: items.reduce((acc, item) => {\n    Object.assign(acc, item.json);\n    return acc;\n  }, {})\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2832,
        -160
      ],
      "id": "c8267b27-d981-404b-9464-27d6818864ed",
      "name": "Flatten JSON structure"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const {\n    titleGerman = \"Ohne Titel\",\n    author = \"Unbekannt\",\n    date = new Date().toISOString(),\n    url = '',\n    slug = titleGerman.toLowerCase().replace(/\\s+/g, '-').replace(/[^\\w-]/g, ''),\n    articleGerman = ''\n  } = item.json;\n  \n  const yaml = [\n    '---',\n    `title: \"${titleGerman.replace(/\"/g, '\\\\\"')}\"`,\n    `author: \"${author.replace(/\"/g, '\\\\\"')}\"`,\n    `date: \"${date}\"`,\n    `showdate: true`,\n    `slug: \"${slug}\"`,\n    `weight: 1000`,\n    `tags: []`,\n    `books: []`,\n    `draft: false`,\n    '---'\n  ].join('\\n');\n\n  const mdLink = `[Theopolis Institute](${url})`\n  \n  const markdown = `${yaml}\\n\\n${articleGerman.trim()}\\n\\n${mdLink}}`;\n\n  return {\n    json: {\n      ...item.json,\n      slug,\n      markdownContent: markdown\n    }\n  };\n});\n"
      },
