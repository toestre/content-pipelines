      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const text = $json[\"markdown\"]; // falls dein Markdown in einem Feld \"markdown\" liegt\n\n// Regex: alles ab erster wirklicher Absatz bis \"Related Media\" oder \"To download\"\nconst match = text.match(/(?:\\*FILED UNDER\\*[\\s\\S]+?\\n\\n)([\\s\\S]*?)(?=\\n\\nRelated Media|\\n\\nTo download)/);\n\nreturn {\n  ...item.json,\n  article: match ? match[1].trim() : null\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        992,
        -160
      ],
      "id": "da782b22-90ce-462e-b60c-db8359b6f9ec",
      "name": "First filter stage - extract article roughly"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const text = $json[\"article\"];\n\n// Alles ab dem ersten Absatz, der mit Großbuchstabe startet\nconst cleanStart = text.replace(/^[\\s\\S]*?\\n\\n([A-Z][\\s\\S]*)/, \"$1\");\n\n// Alles bis vor \"* * *\" oder dem Autor-Absatz\nconst match = cleanStart.match(/([\\s\\S]*?)(?=\\n\\n\\* \\* \\*|\\n\\n_[A-Z][\\s\\S]*_|\\n\\n\\[Consumerism|\\n\\nRelated Media|\\n\\nTo download)/);\n\nreturn {\n  ...item.json,\n  article: match ? match[1].trim() : cleanStart.trim()\n};\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
